# labelforge environment — copy to .env and fill in your values.
# All variables are read by pydantic-settings; names are case-insensitive.

# REQUIRED: shared secret for the HTTP API.  All /api/* routes (except /api/health)
# require:  Authorization: Bearer <API_TOKEN>
API_TOKEN=changeme

# REQUIRED: IP or hostname of the Brother QL printer.
# For network backend this becomes tcp://<PRINTER_HOST>:9100.
PRINTER_HOST=192.168.1.x

# Brother QL model identifier, must match brother_ql's model list.
PRINTER_MODEL=QL-820NWB

# Printer connection backend: network | linux_kernel | pyusb
PRINTER_BACKEND=network

# Label media loaded in the printer by default (used as UI pre-selection).
DEFAULT_LABEL_MEDIA=62

# Host path where SQLite, labels.yml, fonts, and previews are stored.
# Must be bind-mounted into the container at the same path.
DATA_DIR=/var/docker/labelforge

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
