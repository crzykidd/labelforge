# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
# uv is not this project's toolchain (Dockerfile uses pip + hatchling); lockfile is a local artifact
uv.lock

# Sandbox-mounted host dotfiles (not project files)
.bash_profile
.bashrc
.gitconfig
.gitmodules
.idea
.mcp.json
.profile
.ripgreprc
.zprofile
.zshrc

# Build artifacts
build/
dist/
*.whl

# Node / Vite
node_modules/
.vite/
*.tsbuildinfo

# Frontend build output (consumed by FastAPI in container build)
frontend/dist/
# Compiled TS output emitted next to source (tsc artifacts; not used by Vite)
frontend/src/**/*.js

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local environment
.env
.env.local
*.env.local

# Runtime data (should never be committed)
data/
data-dev/
*.db
*.db-journal
*.sqlite
*.sqlite3

# Leftover vexp index dir — vexp is de-adopted (see standards.md), but its host
# daemon keeps regenerating .vexp/ until host teardown lands in the ansible repo.
# Ignored only to prevent accidentally committing regenerated index state.
.vexp/

# Logs
*.log
logs/

# claude — ignore the dir but track the shared settings.json. Any per-host
# auto-generated .claude/CLAUDE.md and settings.local.json stay ignored.
.claude/*
!.claude/settings.json

# Test artifacts
.coverage
htmlcov/
coverage.xml
test-print.json
