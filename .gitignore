# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Build artifacts
build/
dist/
*.whl

# Node / Vite
node_modules/
.vite/
*.tsbuildinfo

# Frontend build output (consumed by FastAPI in container build)
frontend/dist/
# Compiled TS output emitted next to source (tsc artifacts; not used by Vite)
frontend/src/**/*.js

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local environment
.env
.env.local
*.env.local

# Runtime data (should never be committed)
data/
data-dev/
*.db
*.db-journal
*.sqlite
*.sqlite3

# vexp (standalone systemd-user daemon — all runtime state is per-host and regenerable;
# manifest.json intentionally NOT tracked, per the vexp-context-engine standard's
# "each host owns its index" shape). The .vexpignore at the repo root IS tracked.
.vexp/
vexp.toml

# Logs
*.log
logs/

# claude — ignore the dir but track shared artifacts (settings.json, the hooks/ dir).
# .claude/CLAUDE.md is vexp's per-host auto-generated file: left untracked (the verbatim
# vexp snippet lives in the tracked root CLAUDE.md instead). settings.local.json stays ignored.
.claude/*
!.claude/settings.json
!.claude/hooks/

# Test artifacts
.coverage
htmlcov/
coverage.xml
test-print.json
