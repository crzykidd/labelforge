# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Build artifacts
build/
dist/
*.whl

# Node / Vite
node_modules/
.vite/
*.tsbuildinfo

# Frontend build output (consumed by FastAPI in container build)
frontend/dist/
# Compiled TS output emitted next to source (tsc artifacts; not used by Vite)
frontend/src/**/*.js

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local environment
.env
.env.local
*.env.local

# Runtime data (should never be committed)
data/
data-dev/
*.db
*.db-journal
*.sqlite
*.sqlite3

# vexp (VS Code extension daemon — all runtime state, config regenerable)
.vexp/
vexp.toml

# Logs
*.log
logs/

# claude 
.claude/

# Test artifacts
.coverage
htmlcov/
coverage.xml
test-print.json
